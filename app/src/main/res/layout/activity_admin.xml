<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FDF6FD"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Dashboard"
            android:textColor="#7B2CBF"
            android:textStyle="bold"
            android:textSize="28sp"
            android:layout_marginBottom="24dp"/>

        <Button
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Manage Products"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#9D4EDD"
            android:layout_marginBottom="16dp"/>

        <Button
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Manage Quantity"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7B2CBF"
            android:layout_marginBottom="16dp"/>

        <Button
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Firebase Connected"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5A189A"
            android:layout_marginBottom="20dp"/>

        <EditText
            android:id="@+id/productIdEdt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Product ID"/>

        <EditText
            android:id="@+id/newPriceEdt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="New Price"
            android:inputType="numberDecimal"
            android:layout_marginTop="12dp"/>

        <Button
            android:id="@+id/updatePriceBtn"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Update Product Price"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7B2CBF"
            android:layout_marginTop="20dp"/>

        <EditText
            android:id="@+id/quantityEdt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="New Quantity"
            android:inputType="number"
            android:layout_marginTop="16dp"/>

        <Button
            android:id="@+id/updateQuantityBtn"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Update Quantity"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5A189A"
            android:layout_marginTop="12dp"/>

        <EditText
            android:id="@+id/addProductIdEdt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="New Product ID"
            android:layout_marginTop="20dp"/>

        <EditText
            android:id="@+id/addProductTitleEdt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Product Title"
            android:layout_marginTop="12dp"/>

        <EditText
            android:id="@+id/addProductPriceEdt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Product Price"
            android:inputType="numberDecimal"
            android:layout_marginTop="12dp"/>

        <Button
            android:id="@+id/addProductBtn"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Add Product"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7B2CBF"
            android:layout_marginTop="12dp"/>

        <Button
            android:id="@+id/deleteProductBtn"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Delete Product"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#D00000"
            android:layout_marginTop="12dp"/>

    </LinearLayout>

</ScrollView>